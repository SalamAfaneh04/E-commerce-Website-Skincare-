@model IEnumerable<E_commerce_Website__Skincare_.Models.Order>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Orders";
    ViewData["ActivePage"] = "Orders";
}

<!-- Stats Cards -->
<div class="grid grid-cols-4 gap-6 mb-10">
    <div class="bg-surface-container-low p-6 rounded-xl border border-white/40 hover:-translate-y-0.5 transition-transform"
         style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Total Orders</p>
        <h3 class="text-3xl font-medium" style="font-family:'Playfair Display',serif;">@Model.Count()</h3>
    </div>
    <div class="bg-surface-container-low p-6 rounded-xl border border-white/40 hover:-translate-y-0.5 transition-transform"
         style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Processing</p>
        <h3 class="text-3xl font-medium text-primary" style="font-family:'Playfair Display',serif;">@Model.Count(o => o.Status == "Processing")</h3>
    </div>
    <div class="bg-surface-container-low p-6 rounded-xl border border-white/40 hover:-translate-y-0.5 transition-transform"
         style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Completed</p>
        <h3 class="text-3xl font-medium" style="font-family:'Playfair Display',serif; color:#3a7d5a;">@Model.Count(o => o.Status == "Completed")</h3>
    </div>
    <div class="bg-surface-container-low p-6 rounded-xl border border-white/40 hover:-translate-y-0.5 transition-transform"
         style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Cancelled</p>
        <h3 class="text-3xl font-medium" style="font-family:'Playfair Display',serif; color:#ba1a1a;">@Model.Count(o => o.Status == "Cancelled")</h3>
    </div>
</div>

<!-- Filter Bar -->
<div class="bg-surface-container-low rounded-xl px-6 py-4 mb-6 flex items-center gap-4"
     style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
    <div class="relative flex-1 max-w-xs">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant opacity-60" style="font-size:18px;">search</span>
        <input id="searchInput" type="text" placeholder="Search by name or order ID..."
               class="w-full bg-surface border border-outline-variant rounded-full py-2 pl-9 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all" />
    </div>
    <select id="statusFilter"
            class="bg-surface border border-outline-variant rounded-full py-2 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all">
        <option value="">All Statuses</option>
        <option value="Processing">Processing</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
    </select>
    <span class="ml-auto text-sm text-on-surface-variant">
        Results: <strong id="resultCount">@Model.Count()</strong>
    </span>
</div>

<!-- Orders Table -->
<div class="bg-surface-container-low rounded-xl overflow-hidden"
     style="box-shadow: 0 10px 30px -5px rgba(80,64,48,0.06);">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-outline-variant">
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">#</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Customer</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Date</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Total</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Status</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Change Status</th>
                <th class="text-left px-6 py-4 text-xs font-semibold tracking-widest text-on-surface-variant uppercase">Actions</th>
            </tr>
        </thead>
        <tbody id="ordersTableBody">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-16 text-on-surface-variant opacity-60">
                        <span class="material-symbols-outlined" style="font-size:48px;">shopping_cart</span>
                        <p class="mt-2">No orders found</p>
                    </td>
                </tr>
            }
            @{ int counter = 1; }
            @foreach (var order in Model)
            {
                <tr class="border-b border-outline-variant/50 hover:bg-surface-container transition-colors"
                    data-id="@order.Id"
                    data-name="@(order.User?.FullName?.ToLower())"
                    data-status="@order.Status">
                    <td class="px-6 py-4 text-on-surface-variant">@counter</td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container text-xs font-bold">
                                @((order.User?.FullName ?? "U").Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <p class="font-semibold text-on-surface">@(order.User?.FullName ?? "Deleted User")</p>
                                <p class="text-xs text-on-surface-variant opacity-70">@(order.User?.Email ?? "")</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-on-surface-variant">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                    <td class="px-6 py-4 font-semibold text-on-surface">$@order.TotalAmount.ToString("F2")</td>
                    <td class="px-6 py-4">
                        @if (order.Status == "Completed")
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#d1fae5; color:#065f46;">Completed</span>
                        }
                        else if (order.Status == "Cancelled")
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#fde8e8; color:#9b1c1c;">Cancelled</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#fef3c7; color:#92400e;">Processing</span>
                        }
                    </td>
                    <td class="px-6 py-4">
                        @{
                            var statusOptions = new[] { "Processing", "Completed", "Cancelled" };
                        }
                        <select class="status-select bg-surface border border-outline-variant rounded-lg py-1.5 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                                data-order-id="@order.Id">
                            @foreach (var status in statusOptions)
                            {
                                <option value="@status" selected="@(order.Status == status ? "selected" : null)">@status</option>
                            }
                        </select>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <button onclick="showOrderDetails(@order.Id)"
                                    class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold bg-primary-container text-on-primary-container hover:opacity-80 transition-opacity">
                                <span class="material-symbols-outlined" style="font-size:14px;">visibility</span>
                                Details
                            </button>
                            <button onclick="deleteOrder(@order.Id)"
                                    class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold hover:bg-surface-container transition-colors text-on-surface-variant">
                                <span class="material-symbols-outlined" style="font-size:14px;">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                counter++;
            }
        </tbody>
    </table>
</div>

<!-- Order Details Modal -->
<div id="orderDetailsModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/30 backdrop-blur-sm" onclick="closeOrderDetails()"></div>
    <div class="absolute right-0 top-0 h-full w-[520px] bg-surface shadow-2xl overflow-y-auto">
        <div class="flex justify-between items-center px-8 py-6 border-b border-outline-variant sticky top-0 bg-surface z-10">
            <h3 class="text-xl font-semibold" style="font-family:'Playfair Display',serif;">Order Details</h3>
            <button onclick="closeOrderDetails()" class="text-on-surface-variant hover:text-on-surface">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div id="orderDetailsBody" class="p-8">
            <div class="flex items-center justify-center py-16">
                <div class="animate-spin rounded-full h-8 w-8 border-2 border-primary border-t-transparent"></div>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="fixed bottom-6 right-6 z-50 hidden">
    <div class="bg-on-surface text-surface px-5 py-3 rounded-xl text-sm font-semibold shadow-xl">
        <span id="toastMsg"></span>
    </div>
</div>

@section Scripts {
<script>
    // Order Details
    function showOrderDetails(orderId) {
        document.getElementById('orderDetailsModal').classList.remove('hidden');
        document.getElementById('orderDetailsBody').innerHTML = `
            <div class="flex items-center justify-center py-16">
                <div class="animate-spin rounded-full h-8 w-8 border-2 border-primary border-t-transparent" style="border-color:#635f40; border-top-color:transparent;"></div>
            </div>`;
        fetch(`/Admin/OrderDetails/${orderId}`)
            .then(r => r.text())
            .then(html => document.getElementById('orderDetailsBody').innerHTML = html);
    }

    function closeOrderDetails() {
        document.getElementById('orderDetailsModal').classList.add('hidden');
    }

    // Change Status
    document.querySelectorAll('.status-select').forEach(select => {
        select.addEventListener('change', function () {
            fetch('/Admin/UpdateOrderStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `orderId=${this.dataset.orderId}&status=${this.value}`
            })
            .then(r => r.json())
            .then(data => { if (data.success) showToast('Status updated successfully'); });
        });
    });

    // Delete Order
    function deleteOrder(orderId) {
        if (!confirm('Are you sure you want to delete this order?')) return;
        fetch('/Admin/DeleteOrder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `orderId=${orderId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                document.querySelector(`tr[data-id="${orderId}"]`).remove();
                updateCount();
                showToast('Order deleted successfully');
            }
        });
    }

    // Filter
    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        let count = 0;
        document.querySelectorAll('#ordersTableBody tr[data-id]').forEach(row => {
            const matchName   = !search || row.dataset.name.includes(search) || row.dataset.id.includes(search);
            const matchStatus = !status || row.dataset.status === status;
            row.style.display = (matchName && matchStatus) ? '' : 'none';
            if (matchName && matchStatus) count++;
        });
        document.getElementById('resultCount').textContent = count;
    }

    document.getElementById('searchInput').addEventListener('input', filterTable);
    document.getElementById('statusFilter').addEventListener('change', filterTable);

    function updateCount() {
        const visible = document.querySelectorAll('#ordersTableBody tr[data-id]:not([style*="none"])').length;
        document.getElementById('resultCount').textContent = visible;
    }

    // Toast
    function showToast(msg) {
        const t = document.getElementById('toast');
        document.getElementById('toastMsg').textContent = msg;
        t.classList.remove('hidden');
        setTimeout(() => t.classList.add('hidden'), 3000);
    }
</script>
}