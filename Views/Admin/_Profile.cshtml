@model E_commerce_Website__Skincare_.Models.ApplicationUser

<!-- Avatar -->
<div class="text-center mb-8">
    <div class="w-20 h-20 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container text-3xl font-bold mx-auto mb-4">
        @(Model.FullName?.Substring(0, 1).ToUpper() ?? "A")
    </div>
    <h4 class="font-semibold text-on-surface" style="font-family:'Playfair Display',serif;">@Model.FullName</h4>
    <p class="text-sm text-on-surface-variant opacity-70">@Model.Email</p>
    <span class="mt-2 inline-block px-3 py-1 rounded-full text-xs font-semibold" style="background:#f2ede8; color:#635f40;">Administrator</span>
</div>

<!-- Form -->
<div class="space-y-5">
    <div>
        <label class="block text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-2">Full Name</label>
        <input id="prof-fullname" type="text" value="@Model.FullName"
               class="w-full bg-surface border border-outline-variant rounded-xl py-3 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all" />
    </div>
    <div>
        <label class="block text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-2">Email</label>
        <input id="prof-email" type="email" value="@Model.Email"
               class="w-full bg-surface border border-outline-variant rounded-xl py-3 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all" />
    </div>

    <div class="border-t border-outline-variant pt-5">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-4">Change Password <span class="normal-case font-normal">(optional)</span></p>
        <div class="space-y-4">
            <input id="prof-password" type="password" placeholder="New password"
                   class="w-full bg-surface border border-outline-variant rounded-xl py-3 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all" />
            <input id="prof-confirm" type="password" placeholder="Confirm new password"
                   class="w-full bg-surface border border-outline-variant rounded-xl py-3 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-all" />
        </div>
    </div>

    <!-- Messages -->
    <div id="prof-success" class="hidden px-4 py-3 rounded-xl text-sm font-semibold" style="background:#d1fae5; color:#065f46;"></div>
    <div id="prof-error" class="hidden px-4 py-3 rounded-xl text-sm font-semibold" style="background:#fde8e8; color:#9b1c1c;"></div>

    <!-- Save Button -->
    <button onclick="saveProfile()"
            class="w-full py-3 rounded-xl text-sm font-semibold text-white transition-opacity hover:opacity-80"
            style="background:#635f40;">
        Save Changes
    </button>
</div>

<script>
    function saveProfile() {
        const fullName    = document.getElementById('prof-fullname').value.trim();
        const email       = document.getElementById('prof-email').value.trim();
        const newPassword = document.getElementById('prof-password').value;
        const confirm     = document.getElementById('prof-confirm').value;

        if (!fullName || !email) {
            showProfMsg('error', 'Full name and email are required');
            return;
        }
        if (newPassword && newPassword !== confirm) {
            showProfMsg('error', 'Passwords do not match');
            return;
        }

        fetch('/Admin/UpdateProfile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `fullName=${encodeURIComponent(fullName)}&email=${encodeURIComponent(email)}&newPassword=${encodeURIComponent(newPassword)}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showProfMsg('success', data.message);
                document.getElementById('prof-password').value = '';
                document.getElementById('prof-confirm').value  = '';
            } else {
                showProfMsg('error', data.message || 'Something went wrong');
            }
        });
    }

    function showProfMsg(type, text) {
        const s = document.getElementById('prof-success');
        const e = document.getElementById('prof-error');
        s.classList.add('hidden');
        e.classList.add('hidden');
        if (type === 'success') { s.textContent = text; s.classList.remove('hidden'); }
        else                    { e.textContent = text; e.classList.remove('hidden'); }
        setTimeout(() => { s.classList.add('hidden'); e.classList.add('hidden'); }, 4000);
    }
</script>