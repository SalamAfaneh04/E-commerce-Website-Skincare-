@model E_commerce_Website__Skincare_.Models.Order

<!-- Order Info -->
<div class="grid grid-cols-2 gap-4 mb-8">
    <div class="bg-surface-container p-4 rounded-xl">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Order ID</p>
        <p class="font-semibold text-on-surface">#@Model.Id</p>
    </div>
    <div class="bg-surface-container p-4 rounded-xl">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Date</p>
        <p class="font-semibold text-on-surface">@Model.OrderDate.ToString("MMM dd, yyyy")</p>
    </div>
    <div class="bg-surface-container p-4 rounded-xl">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Customer</p>
        <p class="font-semibold text-on-surface">@(Model.User?.FullName ?? "Deleted User")</p>
        <p class="text-xs text-on-surface-variant opacity-70">@(Model.User?.Email ?? "")</p>
    </div>
    <div class="bg-surface-container p-4 rounded-xl">
        <p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-1">Status</p>
        @if (Model.Status == "Completed")
        {
            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#d1fae5; color:#065f46;">Completed</span>
        }
        else if (Model.Status == "Cancelled")
        {
            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#fde8e8; color:#9b1c1c;">Cancelled</span>
        }
        else
        {
            <span class="px-3 py-1 rounded-full text-xs font-semibold" style="background:#fef3c7; color:#92400e;">Processing</span>
        }
    </div>
</div>

<!-- Products -->
<p class="text-xs font-semibold tracking-widest text-on-surface-variant uppercase mb-4">Items Ordered</p>

<div class="space-y-3 mb-8">
    @if (Model.OrderItems != null && Model.OrderItems.Any())
    {
        @foreach (var item in Model.OrderItems)
        {
            <div class="flex items-center justify-between p-4 bg-surface-container rounded-xl">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-primary-container/30 flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary" style="font-size:18px;">spa</span>
                    </div>
                    <div>
                        <p class="font-semibold text-sm text-on-surface">@(item.Product?.Name ?? "Deleted Product")</p>
                        <p class="text-xs text-on-surface-variant opacity-70">Qty: @item.Quantity</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="font-semibold text-sm text-on-surface">$@((item.Price * item.Quantity).ToString("F2"))</p>
                    <p class="text-xs text-on-surface-variant opacity-70">$@item.Price.ToString("F2") each</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-center text-on-surface-variant opacity-60 py-8">No items found</p>
    }
</div>

<!-- Total -->
<div class="flex items-center justify-between p-5 rounded-xl" style="background:#635f40;">
    <p class="font-semibold text-white tracking-wide">Total Amount</p>
    <p class="text-2xl font-semibold text-white" style="font-family:'Playfair Display',serif;">
        $@Model.TotalAmount.ToString("F2")
    </p>
</div>