<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GlowCare Admin - @ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#635f40",
                        "primary-container": "#b2ac88",
                        "on-primary-container": "#444024",
                        "surface": "#fdf9f4",
                        "surface-container-low": "#f7f3ee",
                        "surface-container": "#f2ede8",
                        "surface-container-high": "#ece7e3",
                        "surface-variant": "#e6e2dd",
                        "on-surface": "#1c1b19",
                        "on-surface-variant": "#49473d",
                        "outline-variant": "#cbc6b9",
                        "secondary": "#70585b",
                        "secondary-container": "#f8d8db",
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #fdf9f4;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="text-on-surface" style="font-family: Inter, sans-serif;">

    <!-- Sidebar -->
    <aside class="h-screen w-64 fixed left-0 top-0 bg-surface-container-low border-r border-outline-variant flex flex-col p-4 gap-2 z-40">
        <div class="px-2 py-6 mb-4">
            <h1 class="text-2xl font-semibold text-primary" style="font-family: 'Playfair Display', serif;">GlowCare Admin</h1>
            <p class="text-sm text-on-surface-variant opacity-70">Management Portal</p>
        </div>
        <nav class="flex-1 space-y-1">
            <a class="@(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a class="@(ViewData["ActivePage"]?.ToString() == "Users" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="UsersInfo">
                <span class="material-symbols-outlined">group</span>
                <span>Users</span>
            </a>
            <a class="@(ViewData["ActivePage"]?.ToString() == "Categories" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="CategoriesInfo">
                <span class="material-symbols-outlined">category</span>
                <span>Categories</span>
            </a>
            <a class="@(ViewData["ActivePage"]?.ToString() == "Products" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="ProductsInfo">
                <span class="material-symbols-outlined">inventory_2</span>
                <span>Products</span>
            </a>
            <a class="@(ViewData["ActivePage"]?.ToString() == "Orders" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="OrdersInfo">
                <span class="material-symbols-outlined">shopping_cart</span>
                <span>Orders</span>
            </a>
            <a class="@(ViewData["ActivePage"]?.ToString() == "Testimonials" ? "bg-primary-container text-on-primary-container font-semibold" : "text-on-surface-variant hover:bg-surface-variant") rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-controller="Admin" asp-action="Testimonials">
                <span class="material-symbols-outlined">chat_bubble</span>
                <span>Testimonials</span>
            </a>
        </nav>
        <div class="mt-auto pt-4 border-t border-outline-variant">
            <a class="text-on-surface-variant hover:bg-surface-variant rounded-lg flex items-center px-4 py-3 gap-3 transition-colors cursor-pointer"
               onclick="showProfile()">
                <span class="material-symbols-outlined">manage_accounts</span>
                <span>Profile</span>
            </a>
            <a class="text-on-surface-variant hover:bg-surface-variant rounded-lg flex items-center px-4 py-3 gap-3 transition-colors"
               asp-area="Identity" asp-page="/Account/Logout"
               asp-route-returnUrl="@Url.Action("Index", "Home")">
                <span class="material-symbols-outlined">logout</span>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main -->
    <main class="ml-64 min-h-screen">
        <!-- Top Header -->
        <header class="h-20 bg-surface/90 backdrop-blur-md flex items-center justify-between px-10 sticky top-0 z-30 shadow-sm border-b border-surface-container-high">
            <h2 class="text-2xl font-medium text-on-surface" style="font-family: 'Playfair Display', serif;">
                @ViewData["Title"]
            </h2>
            <div class="flex items-center gap-3">
                <div class="text-right">
                    <p class="text-sm font-semibold text-on-surface">@User.Identity?.Name</p>
                    <p class="text-xs text-on-surface-variant opacity-70">Administrator</p>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="p-10">
            @RenderBody()
        </div>
    </main>

    <!-- Profile Modal -->
    <div id="profileModal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/30 backdrop-blur-sm" onclick="closeProfile()"></div>
        <div class="absolute right-0 top-0 h-full w-96 bg-surface shadow-2xl p-8 overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-semibold" style="font-family: 'Playfair Display', serif;">Profile</h3>
                <button onclick="closeProfile()" class="text-on-surface-variant hover:text-on-surface">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div id="profileBody">Loading...</div>
        </div>
    </div>

    @RenderSection("Scripts", required: false)

    <script>
        function showProfile() {
            document.getElementById('profileModal').classList.remove('hidden');
            fetch('/Admin/Profile')
                .then(r => r.text())
                .then(html => document.getElementById('profileBody').innerHTML = html);
        }
        function closeProfile() {
            document.getElementById('profileModal').classList.add('hidden');
        }
    </script>
</body>
</html>